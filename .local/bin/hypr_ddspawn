#!/bin/sh
# Put this in .config/hypr/hyprland.conf

cls="foot"
subcls="$1"  # ex) lf, term, note
cmd="$2"

window_info="$(hyprctl -j clients | jq -e --arg cls "$cls-$subcls" 'map(select(.initialTitle == $cls))[0]')"
if [ "$?" = 0 ]
then
    # echo "Window exists"
    pinned="$(echo "$window_info" | jq '.pinned')"
    if [ "$pinned" = "true" ]
    then
        # hide
        hyprctl --batch "dispatch pin initialtitle:$cls-$subcls ; dispatch movetoworkspacesilent special:$subcls,initialtitle:$cls-$subcls"
    else
        # show
        curr_ws="$(hyprctl -j activeworkspace | jq '.id')"
        hyprctl --batch "dispatch movetoworkspace ${curr_ws},initialtitle:$cls-$subcls; dispatch alterzorder top,initialtitle:$cls-$subcls ; dispatch pin initialtitle:$cls-$subcls"
    fi
else
    if [ -n "$cmd" ]
    then
        foot -T "$cls-$subcls" "$cmd" &
    else
        foot -T "$cls-$subcls" &
    fi
fi
